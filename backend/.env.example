# =
# 本地开发环境变量配置文件
# =

# --- 数据库连接 ---
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# --- JWT 鉴权 (由鉴权开发人员负责使用) ---
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- 管理员初始账号（仅供 bootstrap 脚本使用，禁止提交真实值） ---
ADMIN_BOOTSTRAP_STAFF_CODE=
ADMIN_BOOTSTRAP_DISPLAY_NAME=
ADMIN_BOOTSTRAP_PASSWORD=

# --- AI 大模型 (对接硅基流动，使用 DeepSeek 模型) ---
# 请在此填写可用的 SiliconFlow / DeepSeek key
LLM_API_KEY=
LLM_API_BASE=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V4-Pro
LLM_EMBEDDING_MODEL=BAAI/bge-m3
AI_ALLOW_MOCK_FALLBACK=false
AI_SECOND_REVIEW_ENABLED=true

# --- 应用配置 ---
APP_ENV=development
APP_DEBUG=true
